q -> Write a SQL query that finds, for each user, the length of their longest streak of consecutive daily logins. Return user_id and max_streak, ordered by max_streak descending.
sol 2) -> WITH numbered_logins AS (
    SELECT 
        user_id,
        login_date,
        ROW_NUMBER() OVER (
            PARTITION BY user_id 
            ORDER BY login_date
        ) AS rn
    FROM user_logins
),
streak_groups AS (
    SELECT
        user_id,
        login_date,
        login_date - rn * INTERVAL '1 day' AS streak_group
    FROM numbered_logins
),
streak_lengths AS (
    SELECT
        user_id,
        streak_group,
        COUNT(*) AS streak_length
    FROM streak_groups
    GROUP BY user_id, streak_group
)
SELECT
    user_id,
    MAX(streak_length) AS longest_streak
FROM streak_lengths
GROUP BY user_id
ORDER BY longest_streak DESC;
