q1 -> Write a single SQL query that returns each customer's name, their total spend, and a column showing what percentage of the company's overall revenue that customer accounts for. Only include customers who have placed more than one order. Order the result by percentage descending.
sol 1) -> WITH customer_spend AS (
    SELECT 
        customer_id,
        SUM(amount) AS total_spend,
        COUNT(*) AS order_count
    FROM orders
    GROUP BY customer_id
    HAVING COUNT(*) > 1
)

SELECT 
    c.customer_name,
    cs.total_spend,
    ROUND(
        (cs.total_spend * 100.0) / SUM(cs.total_spend) OVER (),
        2
    ) AS percentage_of_revenue
FROM customer_spend cs
JOIN customers c 
    ON cs.customer_id = c.customer_id
ORDER BY percentage_of_revenue DESC;


